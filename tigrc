# Tig 默认配置
#
# 完整参考请查看 'man tigrc'

# 设置
# --------
# 大部分设置可以通过 toggle-* 操作或选项菜单 (默认绑定到 `o`) 来切换

# 视图设置
#
# 支持的列类型及其选项:
#
#   author, committer
#    - display (enum) [no|full|abbreviated|email|email-user]
#					: 显示作者/提交者信息?
#    - width (int)			: 固定宽度, 非零时生效
#    - maxwidth (int)			: 自动调整宽度上限
#
#   commit-title
#    - display (bool)			: 显示提交标题?
#    - graph (enum) [no|v2|v1]		: 显示提交图? (仅主视图)
#    - refs (bool)			: 显示分支/标签/远程引用? (仅主视图)
#    - overflow (boolint)		: 高亮溢出? 启用时默认为 50
#
#   date
#    - display (enum) [no|default|relative|relative-compact|custom]
#					: 显示日期?
#    - use-author (bool)		: 显示作者日期而非提交者日期?
#    - local (bool)			: 显示本地日期?
#    - format (string)			: 自定义 strftime(3) 格式
#					  注意: %Z 被格式化为 %z
#    - width (int)			: 固定宽度, 非零时生效
#
#   file-name
#    - display (enum) [no|always|auto]	: 显示文件名?
#    - width (int)			: 固定宽度, 非零时生效
#    - maxwidth (int)			: 自动调整宽度上限
#
#   file-size
#    - display (enum) [no|default|units]
#					: 显示文件大小?
#    - width (int)			: 固定宽度, 非零时生效
#
#   id
#    - display (bool)			: 显示提交/树 ID?
#    - width (int)			: 固定宽度, 非零时生效
#
#   line-number
#    - display (bool)			: 显示行号?
#    - interval (int)			: 行号间隔, 默认 5
#    - width (int)			: 固定宽度, 非零时生效
#
#   mode
#    - display (bool)			: 显示文件权限?
#    - width (int)			: 固定宽度, 非零时生效
#
#   ref
#    - display (bool)			: 显示引用名?
#    - width (int)			: 固定宽度, 非零时生效
#    - maxwidth (int)			: 自动调整宽度上限
#
#   status
#    - display (enum) [no|short|long]	: 显示状态标签?
#
#   text
#    - display (bool)			: 显示文本?
#    - commit-title-overflow (boolint)	: 在日志和差异视图中高亮溢出?
#

set blame-view	= id:yes,color file-name:auto author:full committer:no date:default,format="%Y-%m-%d" line-number:yes,interval=1 text
set grep-view	= file-name:no line-number:yes,interval=1 text
set main-view	= line-number:no,interval=5 id:no date:default,format="%Y-%m-%d" author:full committer:no commit-title:yes,graph,refs,overflow=no
set reflog-view	= line-number:no,interval=5 id:yes date:no,format="%Y-%m-%d" author:no committer:no commit-title:yes,refs,overflow=no
set refs-view	= line-number:no id:no date:default,format="%Y-%m-%d" author:full committer:no ref commit-title
set stash-view	= line-number:no,interval=5 id:no date:default,format="%Y-%m-%d" author:full commit-title
set status-view	= line-number:no,interval=5 status:short file-name
set tree-view	= line-number:no,interval=5 mode author:full committer:no file-size date:default,format="%Y-%m-%d" id:no file-name

# 分页器视图
set pager-view	= line-number:no,interval=5 text
set stage-view	= line-number:no,interval=5 text
set log-view	= line-number:no,interval=5 text
set blob-view	= line-number:no,interval=5 text
set diff-view	= line-number:no,interval=5 text:yes,commit-title-overflow=no

# 界面显示设置
set show-changes		= yes		# 在主视图中显示变更提交?
set show-untracked		= yes		# 同时显示未跟踪的变更?
set wrap-lines			= no		# 在分页器视图中折行长行?
set tab-size			= 8		# 展开制表符时使用的空格数
set line-graphics		= default	# 枚举: ascii, default, utf-8, auto
set truncation-delimiter	= ~		# 截断时显示的字符, 或 "utf-8"

# 按类型格式化引用名称:
#  - head		: 当前 HEAD
#  - tag		: 附注标签
#  - local-tag		: 轻量标签
#  - remote		: 远程
#  - tracked-remote	: 当前 HEAD 跟踪的远程
#  - replace		: 替换引用
#  - branch		: 分支
#  - stash		: 贮藏
#  - note		: 备注
#  - prefetch		: `git maintenance` 预取的引用
#  - other		: 其他引用
#
# 期望以空格分隔的格式字符串列表
# 如果未为 `local-tag` 指定格式, 则使用 `tag` 的格式
# 同理, 如果未为 `tracked-remote` 指定格式, 则使用 `remote` 的格式
# 如果未为任何其他引用类型指定格式, 则使用 `branch` 的格式
# 加 `hide:` 前缀可隐藏该引用类型, 例如 `hide:prefetch`
set reference-format		= [branch] <tag> {remote} ~replace~

# 控制 Git 内容读取的设置
set commit-order		= auto		# 枚举: auto, default, topo, date, reverse (主视图)
set status-show-untracked-dirs	= yes		# 显示未跟踪目录中的文件? (状态视图)
set status-show-untracked-files	= yes		# 显示未跟踪文件?
set ignore-space		= no		# 枚举: no, all, some, at-eol (差异视图)
set show-notes			= yes		# 非布尔值时传递为 `--show-notes=...` (差异视图)
#set diff-context		= 3		# diff 变更周围显示的行数 (差异视图)
#set word-diff			= yes		# 显示逐词差异? (差异视图)
#set diff-options		= -C		# `tig show` 的自定义选项 (git-diff)
#set diff-highlight		= yes		# 字符串 (或布尔值): diff-highlight 脚本路径,
						#                   默认为 `diff-highlight`
set diff-indicator		= yes		# 显示 diff +/- 符号?
#set blame-options		= -C -C -C	# `tig blame` 的自定义选项 (git-blame)
set log-options			= --cc --stat	# `tig log` 的自定义选项 (git-log)
#set main-options		= -n 1000	# `tig` 的自定义选项 (git-log)
set mailmap			= yes		# 使用 .mailmap 显示规范名称和邮箱地址?

# 杂项
set start-on-head		= no		# 启动时光标定位到 HEAD 提交?
set refresh-mode		= auto		# 枚举: manual, auto, after-command, periodic
set refresh-interval		= 10		# 刷新间隔 (秒)
set ignore-case			= no		# 枚举: no, yes, smart-case
						# 搜索时忽略大小写?
set wrap-search			= yes		# 搜索时在视图顶部/底部循环?
set focus-child			= yes		# 打开子视图时将焦点移至子视图?
set send-child-enter		= yes		# 将 "回车" 按键传递给子视图?
set horizontal-scroll		= 50%		# 水平滚动列数为宽度的百分比
set split-view-height		= 67%		# 水平分割时底部视图的高度占比
set vertical-split		= auto		# 枚举: horizontal, vertical, auto; 使用 auto 时
						# 在宽度允许时自动切换为水平分割
set split-view-width		= 50%		# 垂直分割时最右侧视图的宽度占比
set editor-line-number		= yes		# 自动传递行号给编辑器? 用于
						# 在特定行打开文件, 例如从 diff 中
set history-size		= 500		# 持久历史大小, 0 为禁用
set mouse			= no		# 启用鼠标支持?
set mouse-scroll		= 3		# 鼠标滚轮滚动行数
set mouse-wheel-cursor		= no		# 优先移动光标而非滚动视图?
set pgrp			= no		# 使 tig 成为进程组领导者?
set pager-autoscroll		= no		# 加载时自动滚动分页器视图?

# 用户自定义命令
# ---------------------
# 这些命令允许在 Tig 内直接运行 shell 命令
# 除非另有指定, 命令在前台运行并
# 显示控制台输出 (如同指定了 '!'). 当指定多个
# 命令选项时行为会组合, 例如 "?<git
# commit" 会提示用户是否执行命令并
# 在完成后退出 Tig
#
#   !	在前台运行命令并显示输出
#   @	在后台运行命令, 无输出
#   ?	执行命令前提示用户确认
#   +	同步运行命令, 并将首行输出回显到状态栏
#   <	执行命令后退出 Tig
#   >	执行命令后立即在上次显示的视图中重新打开 Tig
#
# 用户自定义命令可以引用 Tig 的内部状态
# 使用以下变量名, 在命令运行前替换
# (完整列表见 'man tigrc'):
#
#   %(head)		当前引用 ID, 默认为 HEAD
#   %(commit)		当前提交 ID
#   %(blob)		当前 blob ID
#   %(branch)		当前分支名
#   %(remote)		当前远程名
#   %(tag)		当前标签名
#   %(stash)		当前贮藏名
#   %(directory)	目录树视图中的当前目录路径;
#			根目录时为空
#   %(file)		当前选中的文件
#   %(ref)		blame 给定的引用, 未定义时为 HEAD
#   %(revargs)		命令行传入的版本参数
#   %(fileargs)		命令行传入的文件参数
#   %(cmdlineargs)	命令行传入的其他选项
#   %(diffargs)		`diff-options` 或 `TIG_DIFF_OPTS` 中的差异选项
#   %(prompt)		提示输入参数值
#   %(repo:head)	已检出的分支名
#   %(repo:remote)	已检出分支关联的远程名
#   %(repo:upstream)	已检出分支关联的上游分支

bind main	C	?git cherry-pick %(commit)
bind status	C	!git commit
bind stash	A	?git stash apply %(stash)
bind stash	P	?git stash pop %(stash)
bind stash	!	?git stash drop %(stash)
bind refs	C	?git checkout %(branch)
bind refs	!	?git branch -D %(branch)
bind reflog	C	?git checkout %(branch)
bind reflog	!	?git reset --hard %(commit)

