# 视图专属
bind status	u	status-update		# 暂存/取消暂存文件变更
bind status	!	status-revert		# 还原文件变更
bind status	M	status-merge		# 打开 git-mergetool(1)
# bind status	???	:toggle status		# 显示短或长状态标签
bind stage	u	status-update		# 暂存/取消暂存当前 diff 块
bind stage	1	stage-update-line	# 暂存/取消暂存当前行
bind stage	2	stage-update-part	# 暂存/取消暂存块的部分
bind stage	!	status-revert		# 还原当前 diff 块
bind stage	\	stage-split-chunk	# 拆分当前 diff 块
bind stage	@	:/^@@			# 跳到下一个块
bind stage	[	:toggle diff-context -1	# 减少差异上下文
bind stage	]	:toggle diff-context +1	# 增加差异上下文
bind diff	@	:/^@@			# 跳到下一个块
bind diff	[	:toggle diff-context -1	# 减少差异上下文
bind diff	]	:toggle diff-context +1	# 增加差异上下文
bind pager	@	:/^@@			# 跳到下一个块
bind main	H	:goto HEAD		# 跳到 HEAD 提交
bind main	G	:toggle commit-title-graph # 切换版本图可视化
bind main	F	:toggle commit-title-refs  # 切换引用显示 (标签/分支)
bind reflog	F	:toggle commit-title-refs  # 切换引用显示 (标签/分支)

